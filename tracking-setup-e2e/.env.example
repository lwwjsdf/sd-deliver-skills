# ── 项目启动时必填 ────────────────────────────────────────────
SA_HOST=        # CDP 地址，示例：https://demo.sensorsdata.cn
SA_PROJECT=     # 项目 ID，示例：default
CLIENT_NAME=    # 客户名称，示例：westk

# ── Phase 2 完成后填（客户确认埋点方案后）────────────────────
TRACKING_PLAN_PATH=   # 埋点方案路径，示例：./refrences/tracking-plan.xlsx

# ── Phase 3 元数据导入时填 ────────────────────────────────────
# API_KEY 是神策 Open API 密钥
# 获取方式：神策后台 → 系统管理 → API 密钥 → 创建密钥
# 示例：#K-jHllJkcPOMeRke3Vi5Nokeuc1MDlRZls
API_KEY=

# ── Phase 4b 模拟数据导入时填 ────────────────────────────────
# SA_TRACK_URL 是神策数据接收地址（含 project 参数）
# 获取方式：神策后台 → 数据接入 → HTTP API → 复制接入地址
# 示例：https://demo.sensorsdata.cn/sa?project=default
SA_TRACK_URL=
