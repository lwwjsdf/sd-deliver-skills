# ── 项目启动时必填 ────────────────────────────────────────────
SA_HOST=        # 神策 CDP 地址，不带末尾斜杠，如 https://demo.sensorsdata.cn
SA_PROJECT=     # 项目 ID，登录后 URL 中 project= 的值，如 mpdev
SA_PROJECT_NAME=# 项目显示名（OpenAPI 的 sensorsdata-project header），如 uat、生产环境
                # 注意：可能与 SA_PROJECT 不同，是 CDP 界面中显示的名称
CLIENT_NAME=    # 客户名称，用于输出文件命名

# ── 数据接入 ───────────────────────────────────────────────────
# SA_TRACK_URL 是神策 HTTP API 数据接收地址（BatchConsumer 使用）
# 获取方式：神策后台 → 数据接入 → HTTP API → 复制接入地址
# 示例：https://demo.sensorsdata.cn/sa?project=mpdev
SA_TRACK_URL=

# ── Open API（元数据导入 + 数据查询）────────────────────────────
# API_KEY 是神策 Open API 密钥，用于：
#   1. 元数据导入（import_meta_data.py）
#   2. 导入后校验（validate_import.py / validate_post_import.py）
#   3. UAT 指标验证（validate_uat.py / query_event_properties.py）
# 获取方式：神策后台 → 项目管理 → 权限管理 → 创建 API Key
# 权限需要：Schema管理、数据查询
API_KEY=

# ── 埋点方案 ───────────────────────────────────────────────────
# Tracking Plan 是项目核心交付物，不建议把具体文件路径硬编码在 .env 中。
# 原因：一个项目通常有多端方案（MP/Web/eDM/App）和多个版本。
# 推荐做法：
#   1. 把方案文件放在 references/ 目录
#   2. 每次运行脚本时通过 --tracking-plan 参数指定
#   3. 或在 PROJECT.md 中记录当前生效的版本
# 如需全局默认目录，可取消下面注释：
# TRACKING_PLAN_DIR=./references
