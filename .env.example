# ── 项目启动时必填 ────────────────────────────────────────────
SA_HOST=        # 神策 CDP 地址，不带末尾斜杠，如 https://demo.sensorsdata.cn
SA_PROJECT=     # 项目 ID，登录后 URL 中 project= 的值，如 mpdev
SA_PROJECT_NAME=# 项目显示名（OpenAPI 的 sensorsdata-project header），如 uat、生产环境
                # 注意：可能与 SA_PROJECT 不同，是 CDP 界面中显示的名称
CLIENT_NAME=    # 客户名称，用于输出文件命名

# ── Phase 2 完成后填（客户确认埋点方案后）────────────────────
TRACKING_PLAN_PATH=   # 埋点方案 Excel 的路径，如 ./tracking-plan.xlsx

# ── Phase 4b 模拟数据导入时填 ────────────────────────────────
# SA_TOKEN 是神策 HTTP API 数据接入凭证，不是登录 token
# 获取方式：神策后台 → 数据接入 → HTTP API → 复制 token
SA_TOKEN=

# ── Phase 5/7 元数据导入和数据校验时填 ───────────────────────
# API_KEY 是神策 Open API 密钥，用于元数据管理和数据查询
# 获取方式：神策后台 → 项目管理 → 权限管理 → 创建 API Key
# 权限需要：Schema管理、数据查询
API_KEY=
